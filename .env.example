# Supabase (@nuxtjs/supabase v2 reads the NUXT_PUBLIC_* names)
NUXT_PUBLIC_SUPABASE_URL=
NUXT_PUBLIC_SUPABASE_KEY=      # anon key (client)
NUXT_SUPABASE_SECRET_KEY=    # service role key (server only)

# Amazon SES
NUXT_AWS_REGION=
NUXT_AWS_ACCESS_KEY_ID=
NUXT_AWS_SECRET_ACCESS_KEY=
NUXT_SES_FROM_EMAIL=           # verified sender address
NUXT_SES_FROM_NAME=

# AWS SNS / SQS
NUXT_SQS_QUEUE_URL=            # bounce/complaint queue

# Redis (Railway injects this automatically in production)
REDIS_URL=redis://localhost:6379

# App
NUXT_PUBLIC_APP_URL=http://localhost:3000   # public URL for tracking links
